<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ChocolateyPackageBuilder.Gui.ViewModels"
             xmlns:shared="using:ChocolateyPackageBuilder.Gui.ViewModels"
             x:Name="Root"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="760"
             x:Class="ChocolateyPackageBuilder.Gui.Views.CustomProjectSetupView"
             x:DataType="vm:CustomProjectSetupViewModel"
             Classes="CpbPage">
    <Grid ColumnDefinitions="260,*" ColumnSpacing="24">
        <Border Classes="CpbCard">
            <StackPanel Spacing="18">
                <TextBlock Text="New custom project" FontSize="24" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding Steps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="shared:WizardStepItemViewModel">
                            <Border Classes="CpbStepPill" Classes.current="{Binding IsCurrent}"
                                    Classes.complete="{Binding IsComplete}" Margin="0,0,0,10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Subtitle}" FontSize="12" Opacity="0.7"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Classes="CpbCard" Padding="24">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="18">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding CurrentStepTitle}" FontSize="26" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CurrentStepSubtitle}" Opacity="0.72" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <StackPanel IsVisible="{Binding IsProjectStep}" Spacing="14">
                        <TextBlock Text="Project file" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBox Text="{Binding ProjectPath}" IsReadOnly="True"
                                     PlaceholderText="Choose a .cpbproj path" />
                            <Button Grid.Column="1" Content="Choose location"
                                    Command="{Binding BrowseProjectPathCommand}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsMetadataStep}" Spacing="14">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Package name" FontWeight="SemiBold" />
                                <TextBox Text="{Binding PackageName}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Version" FontWeight="SemiBold" />
                                <TextBox Text="{Binding Version}" />
                            </StackPanel>
                        </Grid>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Maintainer" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Maintainer}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Description" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Description}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsOutputStep}" Spacing="14">
                        <TextBlock Text="Output directory" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBox Text="{Binding OutputDirectory}"
                                     ToolTip.Tip="Used for builds in this app session; .cpbproj files store package metadata, files, and actions." />
                            <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseOutputDirectoryCommand}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsCreateStep}" Spacing="14">
                        <Border Classes="CpbSurface" Padding="18">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Project" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ProjectPath}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding PackageName}" />
                                <TextBlock Text="{Binding OutputDirectory}" Opacity="0.75" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Button Content="Create project" Command="{Binding CreateProjectCommand}" Classes="accent"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Button Content="Back" Command="{Binding PreviousStepCommand}" />
                    <Button Grid.Column="2" Content="Next" Command="{Binding NextStepCommand}"
                            IsVisible="{Binding CanGoNext}" />
                    <Button Grid.Column="2" Content="Create" Command="{Binding CreateProjectCommand}" Classes="accent"
                            IsVisible="{Binding IsCreateStep}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>