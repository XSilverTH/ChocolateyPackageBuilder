<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ChocolateyPackageBuilder.Gui.Features.PackageBuilder"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="760"
             x:Class="ChocolateyPackageBuilder.Gui.Features.PackageBuilder.PackageBuilderView"
             x:DataType="vm:PackageBuilderViewModel">
    <Grid ColumnDefinitions="260,*" Background="{DynamicResource SukiBackgroundBrush}">
        <Border Grid.Column="0" Padding="28" Background="{DynamicResource SukiSurfaceBrush}">
            <Grid RowDefinitions="Auto,Auto,*">
                <StackPanel Spacing="6">
                    <TextBlock Text="Chocolatey" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="Package Builder" FontSize="28" FontWeight="Bold" TextWrapping="Wrap" />
                    <TextBlock
                        Text="Build quick single-installer packages. Use Custom project for action-based installers."
                        TextWrapping="Wrap" Opacity="0.72" Margin="0,12,0,0" />
                </StackPanel>

                <Border Grid.Row="1" Margin="0,36,0,0" Padding="14" CornerRadius="12"
                        Background="{DynamicResource SukiAccentBrush}">
                    <TextBlock Text="Package Builder" Foreground="White" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="28" ColumnDefinitions="2*,*" RowDefinitions="*,Auto" ColumnSpacing="20"
              RowSpacing="20">
            <ScrollViewer Grid.Column="0">
                <StackPanel Spacing="20">
                    <Border Classes="Card" Padding="22" CornerRadius="18"
                            Background="{DynamicResource SukiCardBackgroundBrush}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Installer" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="Choose the installer and confirm the detected silent-install strategy."
                                       Opacity="0.68" />

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <TextBox Text="{Binding InstallerPath}" PlaceholderText="Path to .exe or .msi" />
                                <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseInstallerCommand}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Detected type" FontWeight="SemiBold" />
                                    <Border Padding="12" CornerRadius="10"
                                            Background="{DynamicResource SukiLowBackgroundBrush}">
                                        <TextBlock Text="{Binding DetectedInstallerType}" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Build as" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding InstallerTypes}"
                                              SelectedItem="{Binding SelectedInstallerType}"
                                              HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Grid>

                            <Button Content="Detect installer" Command="{Binding DetectInstallerCommand}"
                                    HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <Border Padding="22" CornerRadius="18" Background="{DynamicResource SukiCardBackgroundBrush}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Package metadata" FontSize="22" FontWeight="SemiBold" />
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="14"
                                  RowSpacing="12">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Package name" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding PackageName}" PlaceholderText="my-package" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Version" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding Version}" PlaceholderText="1.0.0" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Spacing="6">
                                    <TextBlock Text="Maintainer" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding Maintainer}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Description" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding Description}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="6">
                                    <TextBlock Text="Output directory" FontWeight="SemiBold" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <TextBox Text="{Binding OutputDirectory}" />
                                        <Button Grid.Column="1" Content="Browse"
                                                Command="{Binding BrowseOutputDirectoryCommand}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Padding="22" CornerRadius="18"
                    Background="{DynamicResource SukiCardBackgroundBrush}">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Generated script preview" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock
                            Text="Known installers become packages. Unknown installers become editable scaffolds."
                            TextWrapping="Wrap" Opacity="0.68" />
                    </StackPanel>

                    <TextBox Grid.Row="1" Margin="0,16,0,0" Text="{Binding ScriptPreview}" AcceptsReturn="True"
                             IsReadOnly="True" FontFamily="Consolas, monospace" TextWrapping="NoWrap" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.ColumnSpan="2" Padding="18" CornerRadius="18"
                    Background="{DynamicResource SukiCardBackgroundBrush}">
                <Grid ColumnDefinitions="Auto,160,*" ColumnSpacing="16" VerticalAlignment="Center">
                    <Button Content="Build package" Command="{Binding BuildPackageCommand}" Classes="accent"
                            Padding="22,10" />
                    <ProgressBar Grid.Column="1" IsIndeterminate="True" IsVisible="{Binding IsBusy}" Height="6"
                                 VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>